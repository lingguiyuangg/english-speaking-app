# 英语口语练习 App - 环境变量示例
# 复制此文件为 .env.local 并填入你的 API 密钥

# DeepSeek API 密钥（必填）
# 在 https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里云 DashScope API 密钥（用于 CosyVoice TTS，可选但推荐）
# 在 https://dashscope.aliyuncs.com 开通语音合成服务后获取
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
